# omegLOL environment. Copy to `.env` and fill in. NEVER commit `.env` (it is git-ignored).
# Values here are intentionally blank/placeholder — this file documents the keys, not the secrets.

# ---- core (required to run with real accounts + persistence) ----
DATABASE_URL=                 # postgres connection string, e.g. postgres://user:pass@host:5432/omeglol?sslmode=require
BETTER_AUTH_SECRET=           # long random string (openssl rand -base64 32). Signs sessions. SERVER-ONLY.
BETTER_AUTH_URL=              # canonical public URL, e.g. https://omeglol.com (no trailing slash)

# ---- Google OAuth (optional; the button appears only when BOTH are set) ----
GOOGLE_CLIENT_ID=             # public — safe in the client
GOOGLE_CLIENT_SECRET=         # SERVER-ONLY secret — never ship to the browser or commit

# ---- security / hardening ----
NODE_ENV=                     # set to "production" in prod: enables HSTS, secure cookies, https redirect
ALLOWED_ORIGINS=              # comma-separated WS/CORS origin allowlist, e.g. https://omeglol.com,https://www.omeglol.com
                              #   (falls back to BETTER_AUTH_URL, plus localhost in non-production)
TRUST_PROXY_HOPS=1            # number of trusted proxy hops in front (Cloudflare = 1). Do NOT set to a huge number.
MOD_IP_SALT=                  # random salt for the one-way IP hash (moderation clustering + security logs). SERVER-ONLY.
WS_MAX_CONNS_PER_IP=20        # max concurrent WebSocket connections per IP

# ---- moderation admin (who can reach /admin + /api/admin/*; server-verified, never a client flag) ----
ADMIN_EMAILS=                 # recommended: comma-separated account emails (matched against the session)
ADMIN_USER_IDS=              # optional: comma-separated game user ids (matched against the resolved user)
                              #   If BOTH are empty there are no admins and every admin route returns 403.

# ---- TURN / ICE (WebRTC relay for restrictive NATs; served to the client via /api/ice) ----
# Without TURN, users on symmetric-NAT / some mobile+corporate networks match but see a black
# screen. Configure ONE provider. If none are set, the server serves STUN-only (fine for local dev).
# Provider A (recommended): Cloudflare Realtime TURN — set BOTH; the server mints short-lived creds.
CLOUDFLARE_TURN_TOKEN_ID=     # Cloudflare TURN key id
CLOUDFLARE_TURN_API_TOKEN=    # Cloudflare TURN API token — SERVER-ONLY secret
# Provider B: generic coturn REST (HMAC ephemeral) — shared secret + your TURN url(s) below
TURN_SECRET=                  # SERVER-ONLY; matches coturn's static-auth-secret
# Provider C: static long-lived TURN credentials
TURN_USERNAME=
TURN_PASSWORD=
# Shared by B/C: comma-separated TURN url(s), and credential lifetime in seconds
TURN_URLS=                    # e.g. turn:turn.example.com:3478,turns:turn.example.com:5349?transport=tcp
TURN_TTL=3600

# ---- consent / legal ----
TOS_VERSION=2026-07-08        # bump when ToS/Privacy change to force users to re-accept

# ---- observability ----
SENTRY_DSN=                   # Sentry DSN for server error tracking. Unset = disabled (dev/tests). SERVER-ONLY.
                              #   Point an uptime monitor at GET /healthz (200 healthy, 503 if DB is down).

# ---- gameplay tuning (optional; seconds) ----
PORT=8080
T_INTRO=5
T_COUNTDOWN=5
T_ROUND=30
T_SWAP=8
