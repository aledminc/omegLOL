# omegLOL environment. Copy to `.env` and fill in. NEVER commit `.env` (it is git-ignored).
# Values here are intentionally blank/placeholder — this file documents the keys, not the secrets.

# ---- core (required to run with real accounts + persistence) ----
DATABASE_URL=                 # postgres connection string, e.g. postgres://user:pass@host:5432/omeglol?sslmode=require
BETTER_AUTH_SECRET=           # long random string (openssl rand -base64 32). Signs sessions. SERVER-ONLY.
BETTER_AUTH_URL=              # canonical public URL, e.g. https://omeglol.com (no trailing slash)

# ---- Google OAuth (optional; the button appears only when BOTH are set) ----
GOOGLE_CLIENT_ID=             # public — safe in the client
GOOGLE_CLIENT_SECRET=         # SERVER-ONLY secret — never ship to the browser or commit

# ---- security / hardening ----
NODE_ENV=                     # set to "production" in prod: enables HSTS, secure cookies, https redirect
ALLOWED_ORIGINS=              # comma-separated WS/CORS origin allowlist, e.g. https://omeglol.com,https://www.omeglol.com
                              #   (falls back to BETTER_AUTH_URL, plus localhost in non-production)
TRUST_PROXY_HOPS=1            # number of trusted proxy hops in front (Cloudflare = 1). Do NOT set to a huge number.
MOD_IP_SALT=                  # random salt for the one-way IP hash (moderation clustering + security logs). SERVER-ONLY.
WS_MAX_CONNS_PER_IP=20        # max concurrent WebSocket connections per IP

# ---- gameplay tuning (optional; seconds) ----
PORT=8080
T_COUNTDOWN=3
T_ROUND=30
T_SWAP=3
T_RESULT=8
